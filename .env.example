# Application
APP_NAME=Digital FTE Agent
APP_VERSION=1.0.0
ENVIRONMENT=production
DEBUG=false

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql://dte_user:dte_password@localhost:5432/dte_db
POSTGRES_USER=dte_user
POSTGRES_PASSWORD=dte_password
POSTGRES_DB=dte_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40

# AI/OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.7
OPENAI_TOP_P=1

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=digital-fte-group
KAFKA_TOPIC_INQUIRIES=customer_inquiries
KAFKA_TOPIC_RESPONSES=agent_responses
KAFKA_TOPIC_ESCALATIONS=escalations
KAFKA_TOPIC_METRICS=metrics

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_TIMEOUT=300
CELERY_TASK_SOFT_LIMIT=270

# Security
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com
RATE_LIMIT_PER_MINUTE=100

# External Services (set these for actual integrations)
GMAIL_CLIENT_ID=your_gmail_client_id
GMAIL_CLIENT_SECRET=your_gmail_client_secret
GMAIL_WEBHOOK_SECRET=your-random-webhook-secret-here
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=your_twilio_whatsapp_number
TWILIO_MESSAGING_SERVICE_SID=MGyour-messaging-service-sid-here

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090
LOG_LEVEL=INFO
PROMETHEUS_ENABLED=true
OPENTELEMETRY_ENABLED=true

# Reports
REPORT_DELIVERY_TIME=09:00
REPORT_TIMEZONE=UTC
REPORT_RECIPIENTS=support-managers@company.com

# Performance
MAX_CONCURRENT_REQUESTS=100
REQUEST_TIMEOUT=30
RESPONSE_TIME_TARGET=3

# Escalation
ESCALATION_RATE_TARGET=0.20
ESCALATION_RATE_WARNING=0.25
HUMAN_SUPPORT_EMAIL=support@company.com

# Cost Control
MAX_DAILY_COST_USD=2.74  # ~$1000/year

# Feature Flags
ENABLE_CROSS_CHANNEL_CONTEXT=true
ENABLE_SENTIMENT_ANALYSIS=true
ENABLE_DAILY_REPORTS=true
ENABLE_SMART_ESCALATION=true

# Compliance
DATA_RETENTION_DAYS=365
ENABLE_GDPR_COMPLIANCE=true
AUDIT_LOGGING_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=90